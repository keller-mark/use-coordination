    "zustand": "^5.0.4",
    "zod": "^4.3.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^5.16.4",
    "@testing-library/react": "^13.3.0",
    "@types/react": "^18.2.43",
    "@types/lodash-es": "^4.17.12",
    "react": "^18.0.0",
    "vite": "^5.4.0",
    "vitest": "^1.6.1"
